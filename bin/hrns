#!/bin/sh
set -eu
CMD=$(basename -- "$0")
SCRIPT=$0
while [ -L "$SCRIPT" ]; do
  DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT")" && pwd)
  TARGET=$(readlink "$SCRIPT")
  case "$TARGET" in
    /*) SCRIPT=$TARGET ;;
    *) SCRIPT=$DIR/$TARGET ;;
  esac
done
DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT")" && pwd)
TARGET_ROOT=$(pwd)
cd "$DIR/.."
case "$CMD" in
  hrns-line-audit) exec env HRNS_TARGET_ROOT="$TARGET_ROOT" go run ./cmd/hrns line-audit "$@" ;;
  hrns-audit) exec env HRNS_TARGET_ROOT="$TARGET_ROOT" go run ./cmd/hrns audit "$@" ;;
esac
exec env HRNS_TARGET_ROOT="$TARGET_ROOT" go run ./cmd/hrns "$@"
