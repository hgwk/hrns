{
  "name": "@hgwk/hrns",
  "version": "0.1.0",
  "description": "Portable repository audit and test harness scripts.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "hrns": "./bin/hrns.mjs",
    "hrns-audit": "./bin/hrns.mjs",
    "hrns-line-audit": "./scripts/line-audit.mjs"
  },
  "files": [
    "bin/",
    "scripts/",
    "packages/e2e/helpers/servers.ts",
    "packages/desktop/test/desktop-wire-smoke.ts",
    "packages/desktop/test/desktop-wire-smoke-matrix.ts",
    "README.md"
  ],
  "scripts": {
    "audit": "node bin/hrns.mjs audit",
    "audit:all": "node bin/hrns.mjs audit --all",
    "list": "node bin/hrns.mjs list",
    "line-audit": "node scripts/line-audit.mjs"
  },
  "hrns": {
    "auditSets": {
      "default": [
        "verify-line-count.mjs",
        "verify-docs-symbol-sync.mjs",
        "verify-sensitive-config-placeholders.mjs",
        "verify-no-orphan-fixtures.mjs",
        "verify-duplicate-helpers.mjs",
        "verify-thin-barrel-modules.mjs"
      ],
      "all": [
        "verify-line-count.mjs",
        "verify-docs-symbol-sync.mjs",
        "verify-sensitive-config-placeholders.mjs",
        "verify-no-orphan-fixtures.mjs",
        "verify-duplicate-helpers.mjs",
        "verify-thin-barrel-modules.mjs",
        "verify-env-example-symbol-sync.mjs",
        "verify-agent-instruction-drift.mjs",
        "verify-docs-duplication.mjs",
        "verify-doc-proposal.mjs",
        "verify-main-diff-scope.mjs",
        "verify-stop-rule.mjs",
        "verify-elegance-review.mjs"
      ]
    },
    "operational": {
      "requiredRootScripts": [
        "audit",
        "audit:all",
        "line-audit"
      ]
    },
    "agentInstructions": {
      "mode": "warn"
    },
    "docsDuplication": {
      "mode": "warn"
    },
    "docsProposal": {
      "mode": "warn"
    },
    "mainDiff": {
      "mode": "warn"
    },
    "stopRule": {
      "mode": "warn"
    },
    "elegance": {
      "mode": "warn"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
